            "file":"README.md", 
            "content-type":"text/markdown"
        }, 
        "requires-python" : ">=3.7", 
        "authors" : [
            {
                "name":"kimyh", 
                "email":"kim_yh663927@naver.com"
            }
        ], 
        "dependencies" : [],   
